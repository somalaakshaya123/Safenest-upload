# --- Database (SQLite file, no external DB server needed) ---
DATABASE_URL="file:./dev.db"

# --- Auth / session signing secret (generate any long random string) ---
SESSION_SECRET="replace-with-a-long-random-string-min-32-chars"

# --- Secret used to encrypt AI provider API keys at rest in the DB ---
# (Evaluators enter their own LLM API key via the in-app Settings UI —
#  this env var only encrypts that key in storage, it is NOT an LLM key itself)
AI_KEY_ENCRYPTION_SECRET="replace-with-another-long-random-string-min-32-chars"

# --- App ---
NEXT_PUBLIC_APP_NAME="SafeNest AI"
