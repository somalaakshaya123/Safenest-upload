generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  BORROWER
  LENDER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  passwordHash  String
  role          Role     @default(BORROWER)
  otpCode       String?
  otpExpiresAt  DateTime?
  isVerified    Boolean  @default(false)
  isDisabled    Boolean  @default(false)
  preferredLang String   @default("en")
  consentGiven  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]

  @@index([email])
}

// One row per user (or a single global row for "admin/org default") holding
// their BYOK AI configuration. Never store a real key in plaintext.
model AISettings {
  id                String   @id @default(cuid())
  ownerUserId       String   @unique
  provider          String   // "openai" | "anthropic" | "openai_compatible"
  baseUrl           String?  // required for openai_compatible custom endpoints
  model             String   // e.g. "gpt-4o-mini", "claude-sonnet-4-6"
  encryptedApiKey   String   // AES-encrypted, never plaintext
  isActive          Boolean  @default(true)
  lastTestedAt      DateTime?
  lastTestStatus    String?  // "success" | "failed" | null
  lastTestMessage   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Phase 2: one row per user holding their onboarding wizard answers PLUS
// the cached output of the deterministic (non-AI) Financial Health scoring
// engine. Recomputed and overwritten every time the wizard is submitted —
// never touched by any LLM call.
model FinancialProfile {
  id                     String   @id @default(cuid())
  ownerUserId            String   @unique

  // --- raw wizard inputs ---
  employmentType         String   // SALARIED | SELF_EMPLOYED | BUSINESS_OWNER | STUDENT | UNEMPLOYED
  ageBand                String?  // "18-25" | "26-35" | "36-45" | "46-60" | "60+"
  dependents             Int
  state                  String?
  monthlyIncome          Float
  monthlyExpenses        Float
  existingEMIs           Float
  loanPurpose            String   // HOME | VEHICLE | EDUCATION | BUSINESS | PERSONAL | AGRICULTURE | MEDICAL | OTHER
  desiredLoanAmount      Float
  desiredTenureMonths    Int
  hasExistingLoanDefault Boolean  @default(false)
  preferredLanguage      String   @default("en")

  // --- cached deterministic scoring output (see src/lib/scoring.ts) ---
  score                  Int
  band                   String
  dtiRatio               Float
  emiBurdenRatio         Float
  savingsRatio           Float
  estimatedNewEMI        Float
  assumedAnnualRatePct   Float
  breakdownJson          String   // JSON.stringify(ScoreBreakdownItem[])
  recommendationsJson    String   // JSON.stringify(string[])

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Phase 3: one row per loan-document analysis a user runs.
// - rawText / title: what the user pasted or uploaded — never modified.
// - extractedJson / plainSummary / aiProvider / aiModel: produced by a real
//   LLM call through the user's own BYOK key (src/lib/ai/loanExtraction.ts).
//   These fields are AI-GENERATED and always rendered with a
//   "Powered by <provider>/<model>" disclosure in the UI.
// - riskScore / riskBand / riskFlagsJson: produced entirely by the
//   deterministic, hardcoded rule engine in src/lib/riskEngine.ts, run on
//   top of the AI-extracted numbers. No LLM is involved in computing these.
model LoanDocument {
  id              String    @id @default(cuid())
  ownerUserId     String
  title           String?
  rawText         String

  status          String    @default("PENDING") // PENDING | ANALYZED | FAILED
  errorMessage    String?

  aiProvider      String?
  aiModel         String?
  extractedJson   String?
  plainSummary    String?
  analyzedAt      DateTime?

  riskScore       Int?
  riskBand        String?
  riskFlagsJson   String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([ownerUserId])
}

// Phase 5: a lender-created loan product listing. Every field here is
// entered directly by the lender (or a platform admin moderating it) —
// no AI is involved anywhere in the marketplace. Matching against a
// borrower's FinancialProfile is done by the deterministic rule engine in
// src/lib/marketplace.ts (same pattern as schemes.ts / loanComparison.ts).
model LoanOffer {
  id                     String   @id @default(cuid())
  lenderUserId           String
  title                  String
  lenderDisplayName      String
  category               String   // PUBLIC_SECTOR_BANK | PRIVATE_BANK | NBFC | FINTECH | GOLD_LOAN | SCHEME_LINKED | OTHER
  purposes               String   // JSON.stringify(LoanPurpose[]) this offer is relevant to
  minAmount              Float
  maxAmount              Float
  minTenureMonths        Int
  maxTenureMonths        Int
  interestRatePct        Float    // headline / starting annual rate
  processingFeePct       Float    @default(0)
  minIncomeRequired      Float?
  eligibleEmploymentTypes String? // JSON.stringify(EmploymentType[]) | null = no restriction
  excludesIfDefault      Boolean  @default(true)
  description            String
  status                 String   @default("ACTIVE") // ACTIVE | PAUSED | REMOVED
  removedReason          String?  // set by admin when status = REMOVED via moderation
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  applications           LoanApplication[]

  @@index([lenderUserId])
  @@index([status])
}

// Phase 5: a borrower's expression of interest / application against a
// LoanOffer. Status is moved along entirely by the lender (or admin) —
// again, no AI involvement; this is a plain workflow/state machine.
model LoanApplication {
  id              String    @id @default(cuid())
  offerId         String
  borrowerUserId  String
  message         String?
  status          String    @default("SUBMITTED") // SUBMITTED | VIEWED | SHORTLISTED | REJECTED | WITHDRAWN
  lenderNote      String?   // private note only the lender/admin can see
  matchScore      Int?      // deterministic match score at time of application (src/lib/marketplace.ts)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  offer           LoanOffer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@index([borrowerUserId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  ipHash    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}
